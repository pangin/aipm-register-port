<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Six product-family icons. Each StreamGeometry is a 24x24 path so they
       render crisply at any size. Style: minimalist line art, single-color. -->

  <!-- SmartPlug — round body + two prongs + cable -->
  <StreamGeometry x:Key="Icon.SmartPlug">M12,2 C16.418,2 20,5.582 20,10 V12 C20,15.314 17.314,18 14,18 H10 C6.686,18 4,15.314 4,12 V10 C4,5.582 7.582,2 12,2 Z M9,7 V10 M15,7 V10 M11,18 V22 M13,18 V22</StreamGeometry>

  <!-- Multi-tap — strip with 3 outlets -->
  <StreamGeometry x:Key="Icon.MultiTap">M3,9 H21 V15 H3 Z M7,12 H7.01 M12,12 H12.01 M17,12 H17.01 M3,12 H1</StreamGeometry>

  <!-- Zigbee Hub — rounded square with 2 wifi arcs -->
  <StreamGeometry x:Key="Icon.ZigbeeHub">M5,4 H19 C20.105,4 21,4.895 21,6 V18 C21,19.105 20.105,20 19,20 H5 C3.895,20 3,19.105 3,18 V6 C3,4.895 3.895,4 5,4 Z M9,11 C10.5,9.5 13.5,9.5 15,11 M11,13.5 C11.5,13 12.5,13 13,13.5</StreamGeometry>

  <!-- IR Remote — rectangle with circle button + signal lines -->
  <StreamGeometry x:Key="Icon.IrRemote">M8,3 H16 C16.552,3 17,3.448 17,4 V20 C17,20.552 16.552,21 16,21 H8 C7.448,21 7,20.552 7,20 V4 C7,3.448 7.448,3 8,3 Z M12,7 A2,2 0 0 1 12,11 A2,2 0 0 1 12,7 M10,15 H14 M10,17 H14 M19,5 L21,3 M19,8 H21 M19,11 L21,13</StreamGeometry>

  <!-- Panelboard — square frame with 2 rows of breakers -->
  <StreamGeometry x:Key="Icon.Panelboard">M4,4 H20 V20 H4 Z M7,8 H10 M14,8 H17 M7,12 H10 M14,12 H17 M7,16 H10 M14,16 H17</StreamGeometry>

  <!-- SolarPlug — sun + plug -->
  <StreamGeometry x:Key="Icon.SolarPlug">M12,3 V5 M3,12 H5 M19,12 H21 M12,19 V21 M5.6,5.6 L7,7 M17,7 L18.4,5.6 M5.6,18.4 L7,17 M17,17 L18.4,18.4 M12,8 A4,4 0 0 1 12,16 A4,4 0 0 1 12,8 M11,12 V14 M13,12 V14</StreamGeometry>

</ResourceDictionary>
