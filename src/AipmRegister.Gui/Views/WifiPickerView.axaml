<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AipmRegister.Gui.ViewModels"
             xmlns:wifi="using:AipmRegister.Core.Wifi"
             xmlns:conv="using:AipmRegister.Gui.Converters"
             xmlns:loc="using:AipmRegister.Gui.Localization"
             x:Class="AipmRegister.Gui.Views.WifiPickerView"
             x:DataType="vm:WifiPickerViewModel">
  <Grid RowDefinitions="Auto,Auto,*,Auto,Auto,Auto" RowSpacing="8">
    <TextBlock Grid.Row="0" FontWeight="SemiBold" FontSize="13"
               Text="{loc:Loc Step1.Title}" />

    <!-- Adapter picker — auto-hidden when there is only one wireless
         interface so the common laptop case looks unchanged. -->
    <Grid Grid.Row="1" ColumnDefinitions="80,*" ColumnSpacing="6"
          IsVisible="{Binding ShowAdapterPicker}">
      <TextBlock Grid.Column="0" VerticalAlignment="Center"
                 Text="{loc:Loc Step1.AdapterLabel}" />
      <ComboBox  Grid.Column="1" HorizontalAlignment="Stretch"
                 ItemsSource="{Binding Interfaces}"
                 SelectedItem="{Binding SelectedInterface, Mode=TwoWay}">
        <ComboBox.ItemTemplate>
          <DataTemplate DataType="wifi:WifiInterface">
            <TextBlock Text="{Binding DisplayName}" />
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
    </Grid>

    <Border Grid.Row="2" BorderBrush="#444" BorderThickness="1" CornerRadius="2">
      <ListBox ItemsSource="{Binding Networks}"
               SelectedItem="{Binding Selected, Mode=TwoWay}"
               Background="Transparent">
        <ListBox.ItemTemplate>
          <DataTemplate DataType="wifi:WifiNetwork">
            <Border Padding="6,3" CornerRadius="2"
                    Background="{Binding IsRecommended, Converter={x:Static conv:WifiRecommendationToBrushConverter.Instance}}">
              <Grid ColumnDefinitions="2*,Auto,Auto,Auto" ColumnSpacing="10">
                <TextBlock Grid.Column="0" Text="{Binding Ssid}"          Foreground="Black" />
                <TextBlock Grid.Column="1" Text="{Binding Band}"          Foreground="Black" Width="40" />
                <TextBlock Grid.Column="2" Text="{Binding SignalQuality}" Foreground="Black" Width="40" />
                <TextBlock Grid.Column="3" Text="{Binding Security}"      Foreground="Black" Width="120" />
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>

    <Button Grid.Row="3" HorizontalAlignment="Left" Padding="10,3"
            Command="{Binding RefreshCommand}"
            Content="{loc:Loc Step1.RefreshButton}" />

    <Grid Grid.Row="4" ColumnDefinitions="80,*" ColumnSpacing="6" Margin="0,2">
      <TextBlock Grid.Column="0" VerticalAlignment="Center"
                 Text="{loc:Loc Step1.SsidLabel}" />
      <TextBox  Grid.Column="1" Text="{Binding Selected.Ssid, Mode=OneWay}" IsReadOnly="True" />
    </Grid>

    <Grid Grid.Row="5" ColumnDefinitions="80,*,Auto" ColumnSpacing="6" Margin="0,2">
      <TextBlock Grid.Column="0" VerticalAlignment="Center"
                 Text="{loc:Loc Step1.PasswordLabel}" />
      <TextBox  Grid.Column="1" PasswordChar="*"
                Text="{Binding HomePassword, Mode=TwoWay}" />
      <Button   Grid.Column="2" Padding="14,4"
                Command="{Binding ConnectCommand}"
                Content="{loc:Loc Step1.ConnectButton}" />
    </Grid>
  </Grid>
</UserControl>
