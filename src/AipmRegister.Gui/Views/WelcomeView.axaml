<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AipmRegister.Gui.ViewModels"
             xmlns:loc="using:AipmRegister.Gui.Localization"
             x:Class="AipmRegister.Gui.Views.WelcomeView"
             x:DataType="vm:WelcomeViewModel">
  <StackPanel Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center">
    <!-- Original wordmark recovered from frmMain's picLogo.BackgroundImage. -->
    <Image Source="/Assets/logo.png" Stretch="Uniform"
           Width="320" HorizontalAlignment="Center" />
    <TextBlock FontSize="13" TextWrapping="Wrap"
               TextAlignment="Center" MaxWidth="500"
               Text="{loc:Loc Welcome.Body}" />
    <Button HorizontalAlignment="Center" Padding="40,8" FontSize="14"
            Command="{Binding StartCommand}"
            Content="{loc:Loc Welcome.StartButton}" />
  </StackPanel>
</UserControl>
