<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AipmRegister.Gui.ViewModels"
             xmlns:models="using:AipmRegister.Core.Models"
             xmlns:conv="using:AipmRegister.Gui.Converters"
             xmlns:loc="using:AipmRegister.Gui.Localization"
             x:Class="AipmRegister.Gui.Views.ProductPickerView"
             x:DataType="vm:ProductPickerViewModel">
  <Grid RowDefinitions="Auto,*,Auto" RowSpacing="8">
    <TextBlock Grid.Row="0" FontWeight="SemiBold" FontSize="13"
               Text="{loc:Loc Step3.Title}" />

    <ScrollViewer Grid.Row="1">
      <ListBox ItemsSource="{Binding Products}"
               SelectedItem="{Binding Selected, Mode=TwoWay}"
               Background="Transparent" BorderThickness="0">
        <ListBox.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel Orientation="Horizontal" />
          </ItemsPanelTemplate>
        </ListBox.ItemsPanel>
        <ListBox.ItemTemplate>
          <DataTemplate DataType="models:ProductDefinition">
            <Border Width="180" Height="74" Padding="10" Margin="4"
                    CornerRadius="6" BorderBrush="#666" BorderThickness="1">
              <Grid ColumnDefinitions="Auto,*">
                <Path Grid.Column="0" Width="32" Height="32"
                      Stretch="Uniform" Stroke="{DynamicResource SystemAccentColor}"
                      StrokeThickness="1.4" Fill="Transparent"
                      Data="{Binding IconKey, Converter={x:Static conv:IconKeyToGeometryConverter.Instance}}" />
                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                  <TextBlock FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap"
                             Text="{Binding DisplayKey, Converter={x:Static conv:LocalizedKeyConverter.Instance}}" />
                  <TextBlock FontSize="10" Opacity="0.7" Text="{Binding Tag, StringFormat='Tag: {0}'}" />
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </ScrollViewer>

    <Button Grid.Row="2" HorizontalAlignment="Center" Padding="20,6"
            Command="{Binding NextCommand}"
            Content="{loc:Loc Step3.NextButton}" />
  </Grid>
</UserControl>
