<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AipmRegister.Gui.ViewModels"
             xmlns:loc="using:AipmRegister.Gui.Localization"
             x:Class="AipmRegister.Gui.Views.AuthCodeView"
             x:DataType="vm:AuthCodeViewModel">
  <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="10">
    <TextBlock Grid.Row="0" FontWeight="SemiBold" FontSize="13"
               Text="{loc:Loc Step2.Title}" />

    <Grid Grid.Row="1" ColumnDefinitions="80,*,Auto" ColumnSpacing="6" Margin="0,4">
      <TextBlock Grid.Column="0" VerticalAlignment="Center"
                 Text="{loc:Loc Step2.AuthCodeLabel}" />
      <TextBox  Grid.Column="1" MaxLength="8" PlaceholderText="12345678"
                Text="{Binding AuthCode, Mode=TwoWay}" />
      <Button   Grid.Column="2" Padding="14,4"
                Command="{Binding VerifyCommand}"
                Content="{loc:Loc Step2.AuthButton}" />
    </Grid>

    <Grid Grid.Row="2" ColumnDefinitions="80,*" ColumnSpacing="6" Margin="0,4">
      <TextBlock Grid.Column="0" VerticalAlignment="Center"
                 Text="{loc:Loc Step2.LinkedAccountLabel}" />
      <TextBox  Grid.Column="1" IsReadOnly="True"
                Text="{Binding LinkedAccount, Mode=OneWay}" />
    </Grid>

    <Border Grid.Row="3" BorderBrush="#444" BorderThickness="1" CornerRadius="3" Padding="14"
            Margin="0,8" VerticalAlignment="Center">
      <StackPanel Spacing="10" HorizontalAlignment="Center">
        <!-- Mobile-app screenshot recovered from frmMain's picPcKey.BackgroundImage:
             the original Dawon "발급 키" issuance flow the user has to follow on
             their phone before pasting the 8-digit code into the field above. -->
        <Image Source="/Assets/pc-key-hint.png" Stretch="Uniform"
               Width="360" HorizontalAlignment="Center" />
        <TextBlock TextAlignment="Center" TextWrapping="Wrap" FontSize="12" Opacity="0.9"
                   Text="{loc:Loc Step2.ConfirmHint}" />
      </StackPanel>
    </Border>

    <Button Grid.Row="4" HorizontalAlignment="Center" Padding="20,6"
            Command="{Binding NextCommand}"
            Content="{loc:Loc Step2.NextButton}" />
  </Grid>
</UserControl>
