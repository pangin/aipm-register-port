<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AipmRegister.Gui.ViewModels"
        xmlns:views="using:AipmRegister.Gui.Views"
        xmlns:loc="using:AipmRegister.Gui.Localization"
        x:Class="AipmRegister.Gui.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Width="640" Height="520"
        Title="{Binding [App.Title], Source={x:Static loc:L.Instance}}"
        WindowStartupLocation="CenterScreen">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="/Assets/Icons.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Window.DataTemplates>
    <DataTemplate DataType="vm:WelcomeViewModel">       <views:WelcomeView /> </DataTemplate>
    <DataTemplate DataType="vm:WifiPickerViewModel">    <views:WifiPickerView /> </DataTemplate>
    <DataTemplate DataType="vm:AuthCodeViewModel">      <views:AuthCodeView /> </DataTemplate>
    <DataTemplate DataType="vm:ProductPickerViewModel"> <views:ProductPickerView /> </DataTemplate>
    <DataTemplate DataType="vm:DevicePickerViewModel">  <views:DevicePickerView /> </DataTemplate>
    <DataTemplate DataType="vm:RegisteringViewModel">   <views:RegisteringView /> </DataTemplate>
  </Window.DataTemplates>

  <Grid Margin="14" RowDefinitions="Auto,*">
    <!-- Header: title + language toggle -->
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
      <StackPanel Spacing="0">
        <TextBlock FontSize="18" FontWeight="Bold"
                   Text="{Binding [App.Title], Source={x:Static loc:L.Instance}}" />
        <TextBlock FontSize="11" Opacity="0.7"
                   Text="{Binding [App.SubTitle], Source={x:Static loc:L.Instance}}" />
      </StackPanel>
      <Button Grid.Column="1" Padding="10,4"
              Command="{Binding ToggleLanguageCommand}"
              Content="{Binding [Lang.Toggle], Source={x:Static loc:L.Instance}}" />
    </Grid>

    <!-- Step content -->
    <Border Grid.Row="1" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="4" Padding="12">
      <ContentControl Content="{Binding Current}" />
    </Border>
  </Grid>
</Window>
